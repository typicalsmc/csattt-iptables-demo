[DEFAULT]
bantime  = 120
findtime = 30
maxretry = 3
backend  = polling
usedns   = no

[sshd]
enabled  = true
port     = ssh
filter   = sshd
# Custom ipset-backed action — adds banned IPs to ssh-blocklist ipset
action   = ipset-ssh[name=SSH, port=ssh, protocol=tcp, bantime=120]
logpath  = /var/log/auth.log
maxretry = 3
findtime = 30
bantime  = 120
